# Video folder path (mount point in container)
VIDEO_FOLDER=/path/to/your/videos

# Segment duration in seconds (default: 10)
SEGMENT_DURATION=10

# Server port (default: 8080)
PORT=8080

# Database path (default: ./data/segments.db)
DB_PATH=./data/segments.db

# HLS segment size (should match SEGMENT_DURATION)
HLS_SEGMENT_SIZE=10
